<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link type="text/css" rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css">
    <link type="text/css" rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.0/css/bootstrap.min.css">
    <link type="text/css" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css">
    <link type="text/css" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css">
    <link type="text/css" rel="stylesheet" href="styleses.css">
    <link type="text/css" rel="stylesheet" href="sty.css">
    <link type="text/css" rel="stylesheet" href="img_slider.css">
    <link type="text/css" rel="stylesheet" href="product.css">
    <style>
      .clearfix{
         overflow: auto;
      }
   </style>
</head>
<body style="background-color:#D0CDD5;">
  <div class="overlay menu">
    <ul>
      <% if(auth_email){ %>
        <li><a href="/admin-panel" style="color: rgb(84, 87, 121);padding-left: 20px;"><i class="fa fa-user icon"><p class="more-tab">Admin Dashboard</p></i></a></li>
      <% } %>
      <% if(teacher_email){ %>
        <li><a href="/teacher-admin-panel" style="color: rgb(84, 87, 121);"><i class="fa fa-user icon"><p class="more-tab">Teacher Dshboard</p></i></a></li>
      <% } %>
    </ul>
  </div>

  <div class="top-nav clearfix"><h5 class="logo-tag">z<span>o</span>class</h5></div>
    <div class="container-fluid" ><div style="height: 10vh;"></div> 
    <div class="row" style="height: 430px;">
      <div class="col-md-12" style="padding-left: 15px!important;padding-right: 15px!important;padding-top: 25px!important;">
        <div class="owl-carousel owl-carousel-fullwidth" style="border-radius: 20px!important;">
            <img  src='./uploads/a.jpg' height="430px;" width="100%" style="border-radius: 15px;">  
            <img  src='./uploads/b.jpg' height="430px;" width="100%" style="border-radius: 15px;">    
            <img  src='./uploads/c.jpg' height="430px;" width="100%" style="border-radius: 15px;">    
            <img  src='./uploads/d.jpg' height="430px;" width="100%" style="border-radius: 15px;">    
            <img  src='./uploads/e.jpg' height="430px;" width="100%" style="border-radius: 15px;">    
        </div>
      </div>                      
    </div>
    <div class="row" style="margin-top: 25px;">
      <div class="col-xs-12" style="padding-left: 0!important;padding-right: 0!important;padding-top: 25px!important;">
        <div class="owl-carousel owl-carousel-fullwidth-product">
          <div class="col-xs-12" style="width: 250px;height: 200px;background-color:#f7f7f8;border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin:2px;">
            <img class="img"  src='./uploads/bio-1.png' width="125" height="125">
            <h4 class="font-img">Biology</h4>  
          </div>
          <div class="col-xs-12" style="width: 250px;height: 200px;background-color: #f7f7f8;border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin:2px;">
            <img class="img"  src='./uploads/math-1.png' width="125" height="125">
            <h4 class="font-img">Maths</h4>  
          </div>
          <div class="col-xs-12" style="width: 250px;height: 200px;background-color: #f7f7f8;border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin:2px;">
            <img class="img"  src='./uploads/phy-1.png' width="125" height="125">
            <h4 class="font-img">Physics</h4>  
          </div>
          <div class="col-xs-12" style="width: 250px;height: 200px;background-color: #f7f7f8;border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin:2px;">
            <img class="img"  src='./uploads/che-1.png' width="125" height="125">
            <h4 class="font-img">Chemistry</h4>  
          </div>
          <div class="col-xs-12" style="width: 250px;height: 200px;background-color: #f7f7f8;border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin:2px;">
            <img class="img"  src='./uploads/san-1.png' width="125" height="125">
            <h4 class="font-img">Sanskrit</h4>  
          </div>
        </div>
      </div>                      
    </div>
      <div class="row">                                
        <div class="col-xs-12  col-md-10 col-md-offset-1" style="padding-left: 0!important;padding-right: 0!important;margin-top: 20px;">
          <div class="owl-carousel owl-carousel-fullwidth-a">
           <% if(records.length > 0){records.forEach(function(row){%>
            <div class="cards" style="border-radius:10px;box-shadow:0px 1px 5px 0px rgba(0,0,0,0.4);margin-left: 10px;margin-right: 5px;margin-top: 5px;margin-bottom: 5px;">
              <div class="boxs">  
                <div class='col-xs-12 img-name'>
                  <div class='col-xs-8'><h2 style="margin-top: 75px;color:#675b7e;font-size: 40px;font-weight: 700;letter-spacing: 0.03em;text-align: left;"><%= row.teachername %></h2></div>
                  <div class='col-xs-4'><img class='img2' src='./uploads/<%= row.image %>'></div>
                </div>
                <div class="row">
                  <div class="col-xs-9" style="height: 75px;">
                    <% if(t_id.length > 0){t_id.forEach(function(rowCls){ %>
                      <% if(row.teacher_uid==rowCls.exist_id){%>
                        <% if(row.teacher_uid){ %>
                          <h2 style="font-family: sans-serif;font-weight: 500;font-size: 32px;text-align: left;margin-left: 40px;color:#675b7e;letter-spacing: 0.1em;margin-top: 25px;"><%= rowCls.subject_name %></h2>
                          <h2 style="font-family: sans-serif;font-weight: bold;font-size: 32px;text-align: left;margin-left: 40px;color: #675b7e;margin-top: 25px;letter-spacing: 0.05em;">Start Live Class - <%= rowCls.class_name %>th</h2>
                          
                        <% }%>
                      <% }%>
                     <% })} %>
                    </div>

                <div class="row" style="height: 350px;">
               <% if(t_id==""){ }%>  
               <% if(t_id.length > 0){t_id.forEach(function(rowCls){ %>
                 <% if(rowCls.exist_id==row.teacher_uid && row.teacher_uid==rowCls.teacher_id && rowCls.exist_id==rowCls.teacher_id && teacher_email){%>
                  <div class="col-xs-5 col-xs-offset-7 card-btn">
                    <a class="btn"><p>Join Now</p></a>   
                  </div>
                 <% }else if(rowCls.exist_id==row.teacher_uid && row.teacher_uid==rowCls.teacher_id && rowCls.exist_id==rowCls.teacher_id && auth_email){%>
                          <div class="col-xs-5 col-xs-offset-7 card-btn">
                            <a class="btn"><p>Join Now</p></a>   
                          </div>
                        <% }else if(rowCls.exist_id==row.teacher_uid && row.teacher_uid==rowCls.teacher_id && rowCls.exist_id==rowCls.teacher_id && rowCls.exist_class_name!==class_name){%>
                          <div class="col-xs-5 col-xs-offset-7 card-btn">
                            <a class="btn"><p>Join Now</p></a>   
                          </div>
                        <% }else if(rowCls.exist_id==row.teacher_uid && row.teacher_uid==rowCls.teacher_id && rowCls.exist_id==rowCls.teacher_id && rowCls.exist_class_name==class_name){%>
                          <div class="col-xs-5 col-xs-offset-7 card-btn">
                            <a href="/getStudentUser"  class="btn"><p>Join Now</p></a>   
                          </div>
                        <% }%>
                      <% })} %>
                        </div>
                        </div>
                   </div>
                </div>
            <%  })} %>
                
            </div>
            </div>
            <nav class="bnav">
              <div class="bnav-item">
                <a class="bnav-link-active"><i class="fa fa-home"></i>Home</a>
              </div>
              <div class="bnav-item">
                <a href="#" class="bnav-link"><i class="fa fa-user icon"></i>User</a>
              </div>
              <div class="bnav-item">
                <a href="#" class="bnav-link"><i class="fa fa-cog icon"></i>Setting</a>
              </div>
              <div class="toggle">
                <div class="kebab menu menus">
                  <figure></figure>
                  <figure></figure>
                  <figure></figure>
                </div>
                <h1 class="menu">More</h1>
              </div>
            </nav>
        </div>
    </div> 
  
    <div class="container-fluid" style="height:500px;"></div>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.0/jquery.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.0/js/bootstrap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
  <script src="https://cdn.ckeditor.com/4.9.1/standard/ckeditor.js"></script>
  <script src="main.js" defer></script>
  <script src="img_slider.js" defer></script>
  <script src="product_slider.js" defer></script>
  <script>
    $(document).ready(function(){
      $('.menu').click(function(){
        $('.overlay').toggleClass('active');
        $('ul').toggleClass('active');
      })
    })
  </script>
       </body>
     </html>
